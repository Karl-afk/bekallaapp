{
  "name": "bekallaapp",
  "version": "1.0.0",
  "description": "Add todos and checklists for our house ",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch index.ts",
    "bundle": "esbuild index.ts --bundle --platform=node --target=node20 --outdir=dist --minify",
    "build": "tsc",
    "test": "test",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate src/migrations/migration -d src/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create src/migrations/migration -t",
    "migration:run": "npm run typeorm migration:run -- -d src/data-source.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karl-afk/bekallaapp.git"
  },
  "keywords": [
    "house",
    "todos",
    "reminder",
    "checklist"
  ],
  "author": "Karl Weinmüller",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Karl-afk/bekallaapp/issues"
  },
  "homepage": "https://github.com/Karl-afk/bekallaapp#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "glob": "^13.0.6"
  }
}
